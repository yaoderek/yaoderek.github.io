---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getDesktopProps } from '../lib/os/tree-data';
import Desktop from '../components/os/Desktop.svelte';
import wallpaperSrc from '../assets/wallpaper.jpg';
import finderIcon from '../assets/dock/finder.png';
import notesIcon from '../assets/dock/notes.png';
import photosIcon from '../assets/dock/photos.png';
import previewIcon from '../assets/dock/preview.png';
import mailIcon from '../assets/dock/mail.png';
import githubIcon from '../assets/dock/github.svg';
import trashIcon from '../assets/dock/trash.png';
import '../styles/global.css';

interface Props {
  initialPath?: string | null;
  title: string;
  description: string;
  ogImage?: string | null;
  notFound?: boolean;
}

const {
  initialPath = null,
  title,
  description,
  ogImage = null,
  notFound = false,
} = Astro.props;

const { tree, showResume } = await getDesktopProps();
const wallpaper = await getImage({
  src: wallpaperSrc,
  format: 'webp',
  width: 2560,
  quality: 72,
});

// Real app icons for the dock (PNGs extracted from macOS; GitHub's official
// mark as SVG). webp keeps the alpha channel.
const dockIcon = (src: ImageMetadata) =>
  getImage({ src, format: 'webp', width: 128 });
const [finderI, notesI, photosI, previewI, mailI, trashI] = await Promise.all(
  [finderIcon, notesIcon, photosIcon, previewIcon, mailIcon, trashIcon].map(dockIcon)
);
const dockIcons = {
  finder: finderI.src,
  notes: notesI.src,
  photos: photosI.src,
  preview: previewI.src,
  mail: mailI.src,
  github: githubIcon.src,
  trash: trashI.src,
};
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : null;
const canonicalHref = canonicalUrl?.href ?? null;
// Pages without their own image fall back to a screenshot of the landing
// desktop (public/og.jpg) so shared links always preview the site.
const effectiveOgImage = ogImage ?? `${base}/og.jpg`;
const ogImageAbsolute = Astro.site
  ? new URL(effectiveOgImage, Astro.site).href
  : effectiveOgImage;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalHref && <meta property="og:url" content={canonicalHref} />}
    <meta property="og:image" content={ogImageAbsolute} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageAbsolute} />
    {
      import.meta.env.PROD && (
        <>
          <script is:inline>
            window.goatcounter = {
              endpoint: 'https://yaoderek.goatcounter.com/count',
            };
          </script>
          <script async src={`${base}/_metrics.js`} is:inline></script>
        </>
      )
    }
  </head>
  <body>
    <Desktop
      client:only="svelte"
      tree={tree}
      initialPath={initialPath}
      showResume={showResume}
      notFound={notFound}
      wallpaperUrl={wallpaper.src}
      dockIcons={dockIcons}
    />
    <noscript>
      <main class="noscript-content">
        <slot />
      </main>
    </noscript>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
  }

  /* The desktop island replaces the viewport when JS runs; the noscript
     fallback is the real crawlable / no-JS page, so let it scroll. */
  .noscript-content {
    display: block;
    max-width: 44rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
    overflow: auto;
    height: auto;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    color: #1d1d1f;
  }

  .noscript-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .noscript-content a {
    color: #0066cc;
  }
</style>
